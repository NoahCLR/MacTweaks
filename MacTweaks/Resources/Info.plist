				<string>public.item</string>
			</array>
			<key>NSSendTypes</key>
			<array>
				<string>public.file-url</string>
				<string>NSURLPboardType</string>
				<string>NSFilenamesPboardType</string>
			</array>
		</dict>
		<dict>
			<key>NSMenuItem</key>
			<dict>
				<key>default</key>
				<string>Copy Path</string>
			</dict>
			<key>NSMessage</key>
			<string>copyPath</string>
			<key>NSPortName</key>
			<string>Mac Tweaks</string>
